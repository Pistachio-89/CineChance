{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": ["@typescript-eslint"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "ignorePatterns": [".next/**", "out/**", "build/**", "next-env.d.ts", "*.js", "node_modules/**"],
  "rules": {
    "@typescript-eslint/no-explicit-any": "off",
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": "off",
    "no-console": "error",
    "no-case-declarations": "off",
    "no-empty": "off",
    "@typescript-eslint/no-require-imports": "off"
  },
  "overrides": [
    {
      "files": ["*.js", "src/lib/logger.ts"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["scripts/**", "src/scripts/**", "prisma/**", "seed.ts"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
